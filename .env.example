# Google Places API (New) — used by src/components/GoogleReviews.jsx
# Create a key in Google Cloud Console → APIs & Services → Credentials
# Enable: "Places API (New)"
# Restrict the key:
#   - Application restriction: HTTP referrers → add your domain(s):
#       https://gcwindowcleaning.com.au/*
#       http://localhost:*
#   - API restriction: Places API (New)
VITE_GOOGLE_PLACES_API_KEY=your-key-here
