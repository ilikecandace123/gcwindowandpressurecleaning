# Google Places API key — used SERVER-SIDE ONLY by functions/api/reviews.js
# (a Cloudflare Pages Function). The key is NEVER bundled into client JS.
#
# DO NOT prefix this with VITE_  — that would inline it into client code.
#
# How to set in production:
#   Cloudflare Pages → your project → Settings → Environment variables
#   → Add variable, name: GOOGLE_PLACES_API_KEY, value: <key>, encrypt.
#
# How to set for local dev (wrangler):
#   wrangler pages dev dist --binding GOOGLE_PLACES_API_KEY=...
# or put it in a file ignored by git.
#
# Cloud Console key restrictions (recommended for the server-side key):
#   - Application restrictions: NONE  (Cloudflare Workers have rotating IPs;
#     since the key is no longer exposed in client JS, restriction is less
#     critical, but if you want belt-and-braces, restrict to the Cloudflare
#     egress IP ranges).
#   - API restriction: ONLY "Places API (New)"  ← must set this.
GOOGLE_PLACES_API_KEY=your-key-here
